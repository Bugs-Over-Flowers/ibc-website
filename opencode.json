{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "Database": {
      "description": "Database Specialist",
      "prompt": "{file:.github/agents/database-specialist.md}",
      "permission": {
        "skill": {
          "db-*": "allow",
          "sql-*": "allow",
          "migration-*": "allow",
          "ui-*": "deny"
        }
      }
    },
    "Forms": {
      "description": "Form Specialist",
      "prompt": "{file:.github/agents/form-specialist.md}",
      "permission": {
        "skill": {
          "form-*": "allow",
          "input-*": "allow",
          "react-hook-form-*": "allow"
        }
      }
    },
    "Server": {
      "description": "Server Specialist",
      "prompt": "{file:.github/agents/server-specialist.md}",
      "permission": {
        "skill": {
          "server-*": "allow",
          "api-*": "allow",
          "docker-*": "allow",
          "deploy-*": "ask"
        }
      }
    },
    "Testing": {
      "description": "Testing Specialist",
      "prompt": "{file:.github/agents/testing-specialist.md}",
      "permission": {
        "skill": {
          "test-*": "allow",
          "jest-*": "allow",
          "cypress-*": "allow",
          "playwright-*": "allow"
        }
      }
    },
    "UI": {
      "description": "UI Specialist",
      "prompt": "{file:.github/agents/ui-specialist.md}",
      "permission": {
        "skill": {
          "ui-*": "allow",
          "css-*": "allow",
          "tailwind-*": "allow",
          "db-*": "deny"
        }
      }
    },
    "Validation": {
      "description": "Validation Specialist",
      "prompt": "{file:.github/agents/validation-specialist.md}",
      "permission": {
        "skill": {
          "validation-*": "allow",
          "schema-*": "allow",
          "zod-*": "allow"
        }
      }
    }
  }
}
