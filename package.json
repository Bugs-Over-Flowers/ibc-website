{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "ibc_project",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --bun next dev --turbopack",
    "build": "bun run --bun next build --turbopack",
    "docker:dev": "docker compose up ibc-dev",
    "docker:devb": "docker compose up ibc-dev --build",
    "docker:prod": "docker compose up ibc-prod",
    "docker:prodb": "docker compose up ibc-prod --build",
    "start": "bun run --bun next start",
    "biome:check": "biome check",
    "biome:write": "biome check --write",
    "email:dev": "email dev --dir ./src/lib/resend/templates --port 3050",
    "test": "vitest",
    "test:unit": "vitest run __tests__/unit",
    "test:integration": "vitest run __tests__/integration",
    "test:component": "vitest run __tests__/component/vitest",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:local": "supabase start && vitest",
    "test:local:ui": "supabase start && vitest --ui",
    "bddgen": "bunx bddgen",
    "test:all": "vitest run && bunx bddgen && playwright test",
    "test:e2e": "supabase start && bunx playwright install chromium && bunx bddgen && playwright test",
    "test:e2e:no-submit": "bunx bddgen && playwright test --grep @no-submit",
    "test:e2e:requires-submit": "bunx bddgen && playwright test --grep @requires-submit",
    "test:e2e:ui": "bunx bddgen && playwright test --ui",
    "test:e2e:headed": "bunx bddgen && playwright test --headed",
    "test:e2e:debug": "bunx bddgen && playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "test:e2e:local": "supabase start && bunx bddgen && playwright test",
    "test:e2e:codegen": "playwright codegen http://localhost:3000",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:reset": "supabase db reset",
    "db:gen:types": "supabase gen types typescript --local > src/lib/supabase/db.types.ts",
    "gen:types": "supabase gen types typescript --project-id rpdourwztdpwdebggkkc > src/lib/supabase/db.types.ts",
    "clean": "rm -rf node_modules .next bun.lock"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@dnd-kit/react": "^0.4.0",
    "@react-pdf/renderer": "^4.5.1",
