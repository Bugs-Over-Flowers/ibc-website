    "react-day-picker": "^9.14.0",
    "react-dom": "19.2.5",
    "react-dropzone": "^15.0.0",
    "react-medium-image-zoom": "^5.4.3",
    "react-scan": "^0.5.3",
    "react-to-print": "^3.3.0",
    "resend": "^6.12.2",
    "sanitize-html": "^2.17.3",
    "server-only": "^0.0.1",
    "shadcn": "^4.4.0",
