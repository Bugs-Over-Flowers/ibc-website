{
  "name": "ibc_project",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --bun next dev --turbopack",
    "build": "bun run --bun next build --turbopack",
    "docker:dev": "docker compose up ibc-dev",
    "docker:devb": "docker compose up ibc-dev --build",
    "docker:prod": "docker compose up ibc-prod",
    "docker:prodb": "docker compose up ibc-prod --build",
    "start": "bun run --bun next start",
    "biome:check": "biome check",
    "biome:write": "biome check --write",
    "email:dev": "email dev --dir ./src/lib/resend/templates --port 3050",
    "test": "vitest",
    "test:unit": "vitest run __tests__/unit",
    "test:integration": "vitest run __tests__/integration",
    "test:component": "vitest run __tests__/component/vitest",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:local": "supabase start && vitest",
    "test:local:ui": "supabase start && vitest --ui",
    "test:all": "vitest run && playwright run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "test:e2e:local": "supabase start && playwright test",
    "test:e2e:codegen": "playwright codegen http://localhost:3000",
    "db:gen:types": "supabase gen types typescript --local > src/lib/supabase/db.types.ts",
    "gen:types": "supabase gen types typescript --project-id rpdourwztdpwdebggkkc > src/lib/supabase/db.types.ts"
  },
